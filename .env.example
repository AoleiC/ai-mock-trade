# 柚子 AI skill 环境变量配置模板
#
# 用法：
#   首次使用前，将本文件复制为 .env（与本文件同目录，即项目根目录）：
#     cp .env.example .env
#   然后填入真实的 STOCK_SECRET_KEY。
#
# 注意：
#   - .env.example 仅作模板，可安全提交到仓库；.env 含真实密钥，切勿提交
#   - 下载接口导出的 ai-mock-trade.zip 会自动生成含密钥的 .env，无需手动操作
#   - 运行时若已通过环境变量注入同名变量，文件中的值不会被覆盖（环境变量优先）

# 模拟交易行情网站基地址
STOCK_API_BASE_URL=http://stock.objie.com

# 个人模拟交易密钥（cookie 中的 secret_key，用于接口认证）
STOCK_SECRET_KEY=
